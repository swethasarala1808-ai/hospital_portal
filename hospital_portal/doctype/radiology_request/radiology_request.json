{
 "doctype": "DocType",
 "module": "Hospital Portal",
 "track_changes": 1,
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "print": 1,
   "report": 1,
   "export": 1,
   "import": 1
  },
  {
   "role": "Administrator",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "print": 1,
   "report": 1
  }
 ],
 "name": "Radiology Request",
 "autoname": "format:RR-{YYYY}-{#####}",
 "title_field": "patient_name",
 "fields": [
  {
   "fieldname": "patient_id",
   "fieldtype": "Link",
   "label": "Patient ID",
   "options": "Patient Registration",
   "reqd": 1,
   "in_list_view": 1,
   "bold": 1
  },
  {
   "fieldname": "patient_name",
   "fieldtype": "Data",
   "label": "Patient Name",
   "fetch_from": "patient_id.full_name",
   "read_only": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "requested_by",
   "fieldtype": "Link",
   "label": "Doctor",
   "options": "User"
  },
  {
   "fieldname": "col1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "modality",
   "fieldtype": "Select",
   "label": "Modality",
   "options": "X-Ray\nECG\nEcho\nCT Scan\nMRI\nUltrasound",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "body_part",
   "fieldtype": "Data",
   "label": "Body Part / Region"
  },
  {
   "fieldname": "urgency",
   "fieldtype": "Select",
   "label": "Urgency",
   "options": "Routine\nUrgent\nEmergency",
   "default": "Routine"
  },
  {
   "fieldname": "request_date",
   "fieldtype": "Datetime",
   "label": "Request Date",
   "default": "now"
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Requested\nScheduled\nIn Progress\nReported",
   "default": "Requested",
   "in_list_view": 1
  },
  {
   "fieldname": "sec1",
   "fieldtype": "Section Break",
   "label": "Clinical Details"
  },
  {
   "fieldname": "clinical_indication",
   "fieldtype": "Text",
   "label": "Clinical Indication"
  },
  {
   "fieldname": "col2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "findings",
   "fieldtype": "Text",
   "label": "Findings"
  },
  {
   "fieldname": "impression",
   "fieldtype": "Text",
   "label": "Impression / Diagnosis"
  },
  {
   "fieldname": "report_images",
   "fieldtype": "Attach",
   "label": "Report / Images"
  },
  {
   "fieldname": "verified",
   "fieldtype": "Check",
   "label": "Verified by Radiologist"
  }
 ]
}