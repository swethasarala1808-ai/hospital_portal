{
 "doctype": "DocType",
 "module": "Hospital Portal",
 "track_changes": 1,
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "print": 1,
   "report": 1,
   "export": 1,
   "import": 1
  },
  {
   "role": "Administrator",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "print": 1,
   "report": 1
  }
 ],
 "name": "ICU Monitoring",
 "autoname": "format:ICU-{YYYY}-{#####}",
 "title_field": "patient_name",
 "fields": [
  {
   "fieldname": "patient_id",
   "fieldtype": "Link",
   "label": "Patient ID",
   "options": "Patient Registration",
   "reqd": 1,
   "in_list_view": 1,
   "bold": 1
  },
  {
   "fieldname": "patient_name",
   "fieldtype": "Data",
   "label": "Patient Name",
   "fetch_from": "patient_id.full_name",
   "read_only": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "recorded_by",
   "fieldtype": "Link",
   "label": "ICU Nurse",
   "options": "User",
   "default": "__user"
  },
  {
   "fieldname": "recorded_at",
   "fieldtype": "Datetime",
   "label": "Time",
   "default": "now",
   "in_list_view": 1
  },
  {
   "fieldname": "sec1",
   "fieldtype": "Section Break",
   "label": "Vitals"
  },
  {
   "fieldname": "heart_rate",
   "fieldtype": "Int",
   "label": "Heart Rate (bpm)"
  },
  {
   "fieldname": "bp_systolic",
   "fieldtype": "Int",
   "label": "BP Systolic"
  },
  {
   "fieldname": "bp_diastolic",
   "fieldtype": "Int",
   "label": "BP Diastolic"
  },
  {
   "fieldname": "col1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "spo2",
   "fieldtype": "Float",
   "label": "SpO2 (%)"
  },
  {
   "fieldname": "temperature",
   "fieldtype": "Float",
   "label": "Temperature (\u00b0C)"
  },
  {
   "fieldname": "respiratory_rate",
   "fieldtype": "Int",
   "label": "Respiratory Rate"
  },
  {
   "fieldname": "gcs_score",
   "fieldtype": "Int",
   "label": "GCS Score (3-15)"
  },
  {
   "fieldname": "sec2",
   "fieldtype": "Section Break",
   "label": "Ventilator"
  },
  {
   "fieldname": "ventilator_support",
   "fieldtype": "Check",
   "label": "On Ventilator"
  },
  {
   "fieldname": "ventilator_mode",
   "fieldtype": "Select",
   "label": "Mode",
   "options": "None\nAC\nSIMV\nCPAP\nBiPAP"
  },
  {
   "fieldname": "col2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "fio2",
   "fieldtype": "Float",
   "label": "FiO2 (%)"
  },
  {
   "fieldname": "peep",
   "fieldtype": "Float",
   "label": "PEEP"
  },
  {
   "fieldname": "sec3",
   "fieldtype": "Section Break",
   "label": "Treatment"
  },
  {
   "fieldname": "iv_fluids",
   "fieldtype": "Text",
   "label": "IV Fluids"
  },
  {
   "fieldname": "vasopressors",
   "fieldtype": "Text",
   "label": "Vasopressors"
  },
  {
   "fieldname": "col3",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "sedation",
   "fieldtype": "Text",
   "label": "Sedation"
  },
  {
   "fieldname": "notes",
   "fieldtype": "Text",
   "label": "Clinical Notes"
  }
 ]
}