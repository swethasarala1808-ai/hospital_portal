{
 "doctype": "DocType",
 "module": "Hospital Portal",
 "track_changes": 1,
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "print": 1,
   "report": 1,
   "export": 1,
   "import": 1
  },
  {
   "role": "Administrator",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "print": 1,
   "report": 1
  }
 ],
 "name": "Pharmacy Dispensing",
 "autoname": "format:PD-{YYYY}-{#####}",
 "title_field": "patient_name",
 "fields": [
  {
   "fieldname": "patient_id",
   "fieldtype": "Link",
   "label": "Patient ID",
   "options": "Patient Registration",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "patient_name",
   "fieldtype": "Data",
   "label": "Patient Name",
   "fetch_from": "patient_id.full_name",
   "read_only": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "prescription_id",
   "fieldtype": "Link",
   "label": "Prescription",
   "options": "Prescription"
  },
  {
   "fieldname": "pharmacist",
   "fieldtype": "Link",
   "label": "Pharmacist",
   "options": "User",
   "default": "__user"
  },
  {
   "fieldname": "col1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "dispensed_at",
   "fieldtype": "Datetime",
   "label": "Dispensed At",
   "default": "now"
  },
  {
   "fieldname": "payment_status",
   "fieldtype": "Select",
   "label": "Payment",
   "options": "Pending\nPaid\nWaived",
   "default": "Pending",
   "in_list_view": 1
  },
  {
   "fieldname": "sec1",
   "fieldtype": "Section Break",
   "label": "Medicines Dispensed"
  },
  {
   "fieldname": "medicines_dispensed",
   "fieldtype": "Text",
   "label": "Medicines Dispensed",
   "reqd": 1
  },
  {
   "fieldname": "col2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "total_amount",
   "fieldtype": "Currency",
   "label": "Total Amount"
  },
  {
   "fieldname": "notes",
   "fieldtype": "Text",
   "label": "Notes"
  }
 ]
}