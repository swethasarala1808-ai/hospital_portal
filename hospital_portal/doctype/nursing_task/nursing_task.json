{
 "doctype": "DocType",
 "module": "Hospital Portal",
 "track_changes": 1,
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "print": 1,
   "report": 1,
   "export": 1,
   "import": 1
  },
  {
   "role": "Administrator",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "print": 1,
   "report": 1
  }
 ],
 "name": "Nursing Task",
 "autoname": "format:NT-{YYYY}-{#####}",
 "title_field": "patient_name",
 "fields": [
  {
   "fieldname": "patient_id",
   "fieldtype": "Link",
   "label": "Patient ID",
   "options": "Patient Registration",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "patient_name",
   "fieldtype": "Data",
   "label": "Patient Name",
   "fetch_from": "patient_id.full_name",
   "read_only": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "task_type",
   "fieldtype": "Select",
   "label": "Task Type",
   "options": "Injection\nIV Fluid\nDressing\nMedication\nMonitoring\nOther",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "requested_by",
   "fieldtype": "Link",
   "label": "Requested By",
   "options": "User"
  },
  {
   "fieldname": "col1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "assigned_nurse",
   "fieldtype": "Link",
   "label": "Assigned Nurse",
   "options": "User"
  },
  {
   "fieldname": "scheduled_time",
   "fieldtype": "Datetime",
   "label": "Scheduled Time"
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Pending\nIn Progress\nCompleted\nSkipped",
   "default": "Pending",
   "in_list_view": 1
  },
  {
   "fieldname": "sec1",
   "fieldtype": "Section Break",
   "label": "Task Details"
  },
  {
   "fieldname": "medication",
   "fieldtype": "Data",
   "label": "Medication / Material"
  },
  {
   "fieldname": "dosage",
   "fieldtype": "Data",
   "label": "Dosage"
  },
  {
   "fieldname": "col2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "route",
   "fieldtype": "Select",
   "label": "Route",
   "options": "IV\nIM\nSC\nOral\nTopical"
  },
  {
   "fieldname": "completed_time",
   "fieldtype": "Datetime",
   "label": "Completed Time"
  },
  {
   "fieldname": "notes",
   "fieldtype": "Text",
   "label": "Notes"
  }
 ]
}