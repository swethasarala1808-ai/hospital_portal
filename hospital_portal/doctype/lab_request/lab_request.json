{
 "doctype": "DocType",
 "module": "Hospital Portal",
 "track_changes": 1,
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "print": 1,
   "report": 1,
   "export": 1,
   "import": 1
  },
  {
   "role": "Administrator",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "print": 1,
   "report": 1
  }
 ],
 "name": "Lab Request",
 "autoname": "format:LR-{YYYY}-{#####}",
 "title_field": "patient_name",
 "fields": [
  {
   "fieldname": "patient_id",
   "fieldtype": "Link",
   "label": "Patient ID",
   "options": "Patient Registration",
   "reqd": 1,
   "in_list_view": 1,
   "bold": 1
  },
  {
   "fieldname": "patient_name",
   "fieldtype": "Data",
   "label": "Patient Name",
   "fetch_from": "patient_id.full_name",
   "read_only": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "requested_by",
   "fieldtype": "Link",
   "label": "Doctor",
   "options": "User"
  },
  {
   "fieldname": "consultation_id",
   "fieldtype": "Link",
   "label": "Consultation",
   "options": "Consultation"
  },
  {
   "fieldname": "col1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "request_date",
   "fieldtype": "Datetime",
   "label": "Request Date",
   "default": "now"
  },
  {
   "fieldname": "priority",
   "fieldtype": "Select",
   "label": "Priority",
   "options": "Routine\nUrgent\nStat",
   "default": "Routine",
   "in_list_view": 1
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Requested\nSample Collected\nIn Process\nReported",
   "default": "Requested",
   "in_list_view": 1
  },
  {
   "fieldname": "sec1",
   "fieldtype": "Section Break",
   "label": "Tests Required"
  },
  {
   "fieldname": "test_names",
   "fieldtype": "Text",
   "label": "Tests",
   "reqd": 1
  },
  {
   "fieldname": "clinical_notes",
   "fieldtype": "Text",
   "label": "Clinical Notes"
  },
  {
   "fieldname": "col2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "sample_collected",
   "fieldtype": "Check",
   "label": "Sample Collected"
  },
  {
   "fieldname": "sample_collected_at",
   "fieldtype": "Datetime",
   "label": "Sample Collection Time"
  },
  {
   "fieldname": "sec2",
   "fieldtype": "Section Break",
   "label": "Results"
  },
  {
   "fieldname": "results",
   "fieldtype": "Text",
   "label": "Test Results"
  },
  {
   "fieldname": "report_file",
   "fieldtype": "Attach",
   "label": "Report File"
  },
  {
   "fieldname": "verified",
   "fieldtype": "Check",
   "label": "Verified by Pathologist"
  }
 ]
}