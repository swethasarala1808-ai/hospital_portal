{
 "doctype": "DocType",
 "module": "Hospital Portal",
 "track_changes": 1,
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "print": 1,
   "report": 1,
   "export": 1,
   "import": 1
  },
  {
   "role": "Administrator",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "print": 1,
   "report": 1
  }
 ],
 "name": "Patient Registration",
 "autoname": "format:PAT-{YYYY}-{#####}",
 "title_field": "full_name",
 "fields": [
  {
   "fieldname": "full_name",
   "fieldtype": "Data",
   "label": "Full Name",
   "reqd": 1,
   "in_list_view": 1,
   "bold": 1
  },
  {
   "fieldname": "phone",
   "fieldtype": "Phone",
   "label": "Phone Number",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "col1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "gender",
   "fieldtype": "Select",
   "label": "Gender",
   "options": "\nMale\nFemale\nOther",
   "reqd": 1
  },
  {
   "fieldname": "date_of_birth",
   "fieldtype": "Date",
   "label": "Date of Birth"
  },
  {
   "fieldname": "blood_group",
   "fieldtype": "Select",
   "label": "Blood Group",
   "options": "\nA+\nA-\nB+\nB-\nO+\nO-\nAB+\nAB-"
  },
  {
   "fieldname": "sec1",
   "fieldtype": "Section Break",
   "label": "Visit Details"
  },
  {
   "fieldname": "visit_type",
   "fieldtype": "Select",
   "label": "Visit Type",
   "options": "OPD\nIPD\nEmergency\nDaycare",
   "default": "OPD",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "chief_complaint",
   "fieldtype": "Text",
   "label": "Chief Complaint / Problem",
   "reqd": 1
  },
  {
   "fieldname": "col2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "referred_department",
   "fieldtype": "Select",
   "label": "Referred Department",
   "options": "Consultation / OPD\nEmergency\nLaboratory\nRadiology\nPharmacy\nIPD\nICU",
   "reqd": 1
  },
  {
   "fieldname": "registration_date",
   "fieldtype": "Datetime",
   "label": "Registration Date",
   "default": "now",
   "read_only": 1
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Registered\nWaiting\nVitals Recorded\nIn Consultation\nIn Lab\nIn Radiology\nIn Pharmacy\nAdmitted\nDischarged",
   "default": "Registered",
   "in_list_view": 1,
   "bold": 1
  },
  {
   "fieldname": "sec2",
   "fieldtype": "Section Break",
   "label": "Payment"
  },
  {
   "fieldname": "payment_type",
   "fieldtype": "Select",
   "label": "Payment Type",
   "options": "Cash\nInsurance\nPanel\nGovernment Scheme\nFree",
   "default": "Cash"
  },
  {
   "fieldname": "emergency_contact",
   "fieldtype": "Data",
   "label": "Emergency Contact Name"
  },
  {
   "fieldname": "col3",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "emergency_phone",
   "fieldtype": "Phone",
   "label": "Emergency Contact Phone"
  },
  {
   "fieldname": "address",
   "fieldtype": "Text",
   "label": "Address"
  }
 ]
}