{
 "doctype": "DocType",
 "module": "Hospital Portal",
 "track_changes": 1,
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "print": 1,
   "report": 1,
   "export": 1,
   "import": 1
  },
  {
   "role": "Administrator",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "print": 1,
   "report": 1
  }
 ],
 "name": "Vital Signs",
 "autoname": "format:VS-{YYYY}-{#####}",
 "title_field": "patient_name",
 "fields": [
  {
   "fieldname": "patient_id",
   "fieldtype": "Link",
   "label": "Patient ID",
   "options": "Patient Registration",
   "reqd": 1,
   "in_list_view": 1,
   "bold": 1
  },
  {
   "fieldname": "patient_name",
   "fieldtype": "Data",
   "label": "Patient Name",
   "fetch_from": "patient_id.full_name",
   "read_only": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "recorded_by",
   "fieldtype": "Link",
   "label": "Recorded By (Nurse)",
   "options": "User",
   "default": "__user"
  },
  {
   "fieldname": "recorded_at",
   "fieldtype": "Datetime",
   "label": "Recorded At",
   "default": "now"
  },
  {
   "fieldname": "sec1",
   "fieldtype": "Section Break",
   "label": "Vital Signs"
  },
  {
   "fieldname": "temperature",
   "fieldtype": "Float",
   "label": "Temperature (\u00b0C)"
  },
  {
   "fieldname": "bp_systolic",
   "fieldtype": "Int",
   "label": "BP Systolic (mmHg)"
  },
  {
   "fieldname": "bp_diastolic",
   "fieldtype": "Int",
   "label": "BP Diastolic (mmHg)"
  },
  {
   "fieldname": "col1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "pulse_rate",
   "fieldtype": "Int",
   "label": "Pulse Rate (bpm)"
  },
  {
   "fieldname": "spo2",
   "fieldtype": "Float",
   "label": "SpO2 (%)"
  },
  {
   "fieldname": "respiratory_rate",
   "fieldtype": "Int",
   "label": "Respiratory Rate"
  },
  {
   "fieldname": "sec2",
   "fieldtype": "Section Break",
   "label": "Physical Measurements"
  },
  {
   "fieldname": "height",
   "fieldtype": "Float",
   "label": "Height (cm)"
  },
  {
   "fieldname": "weight",
   "fieldtype": "Float",
   "label": "Weight (kg)"
  },
  {
   "fieldname": "col2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "pain_score",
   "fieldtype": "Int",
   "label": "Pain Score (0-10)"
  },
  {
   "fieldname": "triage_level",
   "fieldtype": "Select",
   "label": "Triage Level",
   "options": "Green - Normal\nYellow - Urgent\nOrange - Very Urgent\nRed - Emergency",
   "in_list_view": 1
  },
  {
   "fieldname": "chief_complaint",
   "fieldtype": "Text",
   "label": "Chief Complaint"
  },
  {
   "fieldname": "notes",
   "fieldtype": "Text",
   "label": "Nurse Notes"
  }
 ]
}