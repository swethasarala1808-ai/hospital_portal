{
 "doctype": "DocType",
 "module": "Hospital Portal",
 "track_changes": 1,
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "print": 1,
   "report": 1,
   "export": 1,
   "import": 1
  },
  {
   "role": "Administrator",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "print": 1,
   "report": 1
  }
 ],
 "name": "Appointment",
 "autoname": "format:APT-{YYYY}-{#####}",
 "title_field": "patient_name",
 "fields": [
  {
   "fieldname": "patient_id",
   "fieldtype": "Link",
   "label": "Patient ID",
   "options": "Patient Registration",
   "reqd": 1,
   "in_list_view": 1,
   "bold": 1
  },
  {
   "fieldname": "patient_name",
   "fieldtype": "Data",
   "label": "Patient Name",
   "fetch_from": "patient_id.full_name",
   "read_only": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "col1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "department",
   "fieldtype": "Select",
   "label": "Department",
   "options": "Consultation / OPD\nEmergency\nLaboratory\nRadiology\nPharmacy\nIPD\nICU",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "appointment_date",
   "fieldtype": "Date",
   "label": "Date",
   "reqd": 1
  },
  {
   "fieldname": "appointment_time",
   "fieldtype": "Time",
   "label": "Time"
  },
  {
   "fieldname": "col2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "token_number",
   "fieldtype": "Int",
   "label": "Token Number",
   "read_only": 1,
   "in_list_view": 1,
   "bold": 1
  },
  {
   "fieldname": "ward_no",
   "fieldtype": "Data",
   "label": "Ward No"
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Scheduled\nWaiting\nIn Progress\nCompleted\nCancelled",
   "default": "Scheduled",
   "in_list_view": 1
  }
 ]
}